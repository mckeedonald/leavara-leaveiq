# =============================================================================
# Guildlight — API Server environment
# Copy to `.env` and fill in. NEVER commit a real .env or real secret values.
# Dev and production MUST use different secrets and a different database.
# =============================================================================

# --- Runtime --------------------------------------------------------------
# "development" enables verbose logging, relaxed rate limits, and dev tooling.
# "production" for deployed environments.
NODE_ENV=development

# Port the API server listens on (required).
PORT=3001

# Log verbosity: trace | debug | info | warn | error (optional; defaults by NODE_ENV)
LOG_LEVEL=debug

# Absolute path to the built frontend to serve in production (optional in dev).
# FRONTEND_DIST_PATH=/app/artifacts/leaveiq/dist/public

# Force the API server to serve the built frontend even when
# NODE_ENV=development. Needed for a DEPLOYED dev environment (e.g. a Railway
# dev service) where no separate Vite dev server is running. Leave unset for
# local dev (Vite serves the UI) and for production (served automatically).
# SERVE_FRONTEND=true

# --- Database (Neon PostgreSQL) -------------------------------------------
# sslmode=require is mandatory; never use plaintext.
# Use a SEPARATE Neon project/branch for dev vs production.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- App URLs -------------------------------------------------------------
# Public base URL of the app; used to build links in outbound email.
# Dev: http://localhost:3001   Prod: https://guildlight.co
APP_URL=http://localhost:3001

# --- Auth / Crypto --------------------------------------------------------
# JWT signing secret — generate with: openssl rand -base64 32
# Production key MUST differ from dev. Changing it invalidates all sessions.
JWT_SECRET=change-me-to-a-random-secret

# AES-256-GCM key for encrypting sensitive fields at rest.
# Generate with: openssl rand -hex 32  (must be 64 hex chars)
ENCRYPTION_KEY=<64-char hex string>

# --- AI (Anthropic Claude) ------------------------------------------------
# Powers the Ave (leave) and Ada agents and the Guildlight Grow agent.
# Rotate via the Anthropic console if compromised; prod key must differ from dev.
ANTHROPIC_API_KEY=sk-ant-...

# --- Email (Resend) -------------------------------------------------------
# Without RESEND_API_KEY, emails are logged to the console instead of sent.
RESEND_API_KEY=re_...
# From address for transactional email (must be a verified guildlight.co sender).
RESEND_FROM_EMAIL=noreply@guildlight.co

# --- File storage (Cloudflare R2) -----------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Seed / admin bootstrap (used by `pnpm run seed-admin` / `db:seed`) ---
ADMIN_EMAIL=admin@guildlight.co
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
ADMIN_POSITION=HR Administrator

# =============================================================================
# Secret rotation
#   ANTHROPIC_API_KEY  — create new key in console, deploy, delete old
#   DATABASE_URL       — rotate Neon password, update host env, redeploy
#   JWT_SECRET         — invalidates all active sessions; use a maintenance window
#   ENCRYPTION_KEY     — requires re-encrypting all stored values; coordinate first
# =============================================================================
