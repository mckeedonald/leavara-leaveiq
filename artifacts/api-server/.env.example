# Database (Neon PostgreSQL) — sslmode=require is mandatory; never use plaintext
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Claude AI — rotate via Anthropic console if compromised; production key must differ from dev
ANTHROPIC_API_KEY=sk-ant-...

# AES-256-GCM key for encrypting sensitive fields at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<64-char hex string>

# Optional — without this, emails log to console instead of sending
RESEND_API_KEY=re_...

# App URL (used in email links)
APP_URL=http://localhost:3001

# JWT secret — generate with: openssl rand -base64 32
# Production key MUST differ from dev/staging
JWT_SECRET=change-me-to-a-random-secret

# Google reCAPTCHA v3 (optional; CAPTCHA is skipped if unset)
RECAPTCHA_SECRET_KEY=

# Rotation procedure:
#   ANTHROPIC_API_KEY  — create new key in console, deploy, delete old
#   DATABASE_URL       — rotate Neon password, update Railway env, redeploy
#   JWT_SECRET         — changing this immediately invalidates all active sessions;
#                        coordinate with a maintenance window; update Railway env
#   ENCRYPTION_KEY     — requires re-encrypting all stored values; contact engineering
