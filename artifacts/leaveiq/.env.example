# =============================================================================
# Guildlight — Frontend (Vite) environment
# Copy to `.env` and fill in. Both variables below are REQUIRED by vite.config.ts.
# =============================================================================

# Dev server port for the Vite frontend (required).
PORT=3000

# Base public path the app is served from (required).
# Dev / root deploy: /        Sub-path deploy: /app/
BASE_PATH=/

# Runtime mode: development | production
NODE_ENV=development
